# Build output
/arrmada
/arrmada.exe
/dist/
/bin/

# Go
/vendor/
*.test
*.out

# Embedded UI build output (generated by the web build)
/internal/webui/dist/*
!/internal/webui/dist/.gitkeep

# Node / frontend
/web/node_modules/
/web/dist/
*.local

# Runtime data (config, db, logs, backups)
/data/
*.db
*.db-shm
*.db-wal
*.log

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Local secrets (TMDB key, etc.)
.env

# User-specific compose override (existing-library mounts)
docker-compose.override.yml
