# Copy to .env and fill in. The install script generates this for you.

# Movie/TV metadata — free v3 API key from https://www.themoviedb.org/settings/api
ARRMADA_TMDB_API_KEY=

# Optional: external ratings (IMDB score, Rotten Tomatoes, Metacritic) on the Discover
# detail modal — free key from https://www.omdbapi.com/apikey.aspx. Without it, the
# modal still shows the TMDB score plus full cast & crew.
ARRMADA_OMDB_API_KEY=

# Host ports. install.sh auto-picks free ones so nothing clashes with Radarr (7878),
# an existing qBittorrent (8080), etc. The app always listens on 7878 *inside* the
# container; ARRMADA_PORT is only the host port it's published on.
ARRMADA_PORT=7878
ARRMADA_QBIT_WEBUI_PORT=8080

# Incoming BitTorrent port. Pick a random high port (the install script does this
# automatically). Arrmada publishes it in Docker AND applies it inside qBittorrent,
# so the two always match — you just forward this port on your router (TCP + UDP).
ARRMADA_QBIT_PORT=6881

# Library folders. By default every module scans one shared library (mounted at /media inside
# the container). To point Movies / TV / Books at SEPARATE folders, set these — each falls back
# to the shared library when unset. EBOOKS and AUDIOBOOKS can be the same path (both under one
# /books folder) or different paths (kept apart).
# ARRMADA_MOVIES_DIR=/media/movies
# ARRMADA_TV_DIR=/media/tvshows
# ARRMADA_EBOOKS_DIR=/media/ebooks
# ARRMADA_AUDIOBOOKS_DIR=/media/audiobooks

# Insights (Plex watch monitoring). Point Arrmada at your Plex server. You can also set
# these in the Insights → Settings UI. Token: in Plex web, play an item → ⋯ → Get Info →
# View XML — the URL ends with X-Plex-Token=...
ARRMADA_PLEX_URL=
ARRMADA_PLEX_TOKEN=
