# Copy to .env and fill in. The install script generates this for you.

# Movie/TV metadata — free v3 API key from https://www.themoviedb.org/settings/api
ARRMADA_TMDB_API_KEY=

# Optional: external ratings (IMDB score, Rotten Tomatoes, Metacritic) on the Discover
# detail modal — free key from https://www.omdbapi.com/apikey.aspx. Without it, the
# modal still shows the TMDB score plus full cast & crew.
ARRMADA_OMDB_API_KEY=

# Incoming BitTorrent port. Pick a random high port (the install script does this
# automatically). Arrmada publishes it in Docker AND applies it inside qBittorrent,
# so the two always match — you just forward this port on your router (TCP + UDP).
ARRMADA_QBIT_PORT=6881
